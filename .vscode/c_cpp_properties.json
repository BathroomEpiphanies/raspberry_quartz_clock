{
  "configurations": [
    {
      "name": "Linux",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/lib/avr/include/"
      ],
      "defines": [
        "VERSION_DATE"
      ],
      "compilerPath": "/usr/bin/avr-gcc",
